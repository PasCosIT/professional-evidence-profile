{
  "version": 2,
  "functions": {
    "api/index.cjs": {
      "includeFiles": "public/**"
    }
  },
  "routes": [
    {
      "methods": ["GET", "POST", "DELETE", "OPTIONS"],
      "src": "/api/(.*)",
      "dest": "/api/index.cjs"
    },
    {
      "handle": "filesystem"
    },
    {
      "methods": ["GET", "HEAD"],
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}