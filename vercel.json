{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "server.cjs",
        "public/**"
      ]
    }
  },
  "routes": [
    {
      "methods": ["GET", "POST", "DELETE", "OPTIONS"],
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "methods": ["GET", "HEAD"],
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}